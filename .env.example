# Ejemplo de variables de entorno para configuración de correo SMTP
# Copia este archivo a ".env" o usa estas variables en Render.

# Modo producción
DEBUG=False
SECRET_KEY=change-me-to-a-strong-secret-key

# Envío de correo SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_contraseña_smtp_o_app_password
DEFAULT_FROM_EMAIL=noreply@cap-online.onrender.com

# NOTA:
# - Si usas Gmail, activa 2FA y crea una contraseña de aplicación.
# - No subas este archivo con valores reales a GitHub.
# - En Render agrega las mismas variables en el panel de Environment.
